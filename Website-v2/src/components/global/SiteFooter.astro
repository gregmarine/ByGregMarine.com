---
import { siteConfig } from "../../../site.config";

const year = new Date().getFullYear();
---

<footer class="w-full border-t border-gray-200 dark:border-gray-800 mt-16 relative z-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col items-center gap-4 sm:flex-row sm:justify-between">

    <!-- Social icons -->
    <ul class="flex items-center gap-4">
      {siteConfig.socialLinks.map((link) => (
        <li>
          <a
            href={link.url}
            aria-label={link.label}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200"
          >
            {link.platform === "instagram" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/>
              </svg>
            )}
            {link.platform === "threads" && (
              <svg viewBox="0 0 192 192" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M141.537 88.988a66.667 66.667 0 0 0-2.518-1.143c-1.482-27.307-16.403-42.94-41.457-43.1h-.34c-14.986 0-27.449 6.396-35.12 18.036l13.779 9.452c5.73-8.695 14.724-10.548 21.348-10.548h.23c8.248.054 14.474 2.452 18.515 7.129 2.954 3.376 4.929 8.142 5.898 14.25-7.345-1.25-15.298-1.636-23.822-1.147-23.982 1.382-39.355 15.368-38.314 34.794.523 9.792 5.707 18.221 14.637 23.73 7.557 4.707 17.288 6.977 27.420 6.420 13.36-.745 23.858-5.834 31.218-15.13 5.685-7.168 9.283-16.45 10.87-28.124 6.52 3.934 11.348 9.183 14.02 15.585 4.66 11.12 4.936 29.399-9.07 43.362-12.265 12.226-27.024 17.533-49.263 17.692-24.704-.177-43.356-8.117-55.44-23.606C22.975 138.64 17.174 120.503 16.947 97.5c.227-23.003 6.028-41.14 17.23-53.959 12.085-13.488 30.737-21.43 55.44-21.607 24.884.179 43.973 8.16 56.763 21.73 6.22 6.69 10.98 15.04 14.19 24.82l16.28-4.308c-3.942-12.12-10.088-22.598-18.39-31.203C141.965 15.96 118.477 6.134 89.839 5.932h-.498C60.925 6.134 37.862 16.035 22.232 34.075 8.188 50.3.956 72.964.703 97.444l-.003.056.003.056c.253 24.48 7.485 47.144 21.529 63.369 15.63 18.04 38.693 27.94 66.608 28.142h.498c24.744-.176 42.05-6.676 56.315-21.047 18.77-18.73 18.174-42.057 12.025-56.413-4.322-10.321-12.485-18.379-23.142-23.619zm-41.069 39.076c-10.508.588-21.44-4.12-21.989-14.224-.396-7.396 5.266-15.655 22.33-16.631 1.956-.113 3.88-.168 5.77-.168 6.14 0 11.91.59 17.19 1.717-1.955 24.375-13.035 28.74-23.301 29.306z"/>
              </svg>
            )}
            {link.platform === "bluesky" && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
              </svg>
            )}
            {link.platform === "x" && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {link.platform === "github" && (
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- All tags link -->
    <a
      href="/tags"
      class="text-sm text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200"
    >
      All tags
    </a>

    <!-- Copyright -->
    <p class="text-sm text-gray-400">
      &copy; {year} by Greg Marine
    </p>

  </div>
</footer>
