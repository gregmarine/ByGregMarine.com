---
import type { CollectionEntry } from "astro:content";
import { collectionSlug } from "@/lib/collection";

interface Props {
  prevPost?: CollectionEntry<"writings"> | null;
  nextPost?: CollectionEntry<"writings"> | null;
  collection: string | null;
  section: string;
  postBasePath?: string;
}

const { prevPost = null, nextPost = null, collection, section, postBasePath = "/writings" } = Astro.props;

const centerLabel = collection ? `All ${collection}` : "All other writings";
const centerHref = collection ? `/${section}/collection/${collectionSlug(collection)}` : `/${section}/other`;
---

<nav
  aria-label="Post navigation"
  class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800"
>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 dark:bg-gray-800 rounded-md overflow-hidden">

    <!-- Previous (older) -->
    <div class="bg-white dark:bg-gray-950 p-5">
      {prevPost ? (
        <a href={`${postBasePath}/${prevPost.id}`} class="group block">
          <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium">
            ← Previous
          </span>
          <p class="mt-1 text-sm font-medium text-gray-900 dark:text-gray-100 group-hover:underline underline-offset-4 leading-snug">
            {prevPost.data.title}
          </p>
          <time class="text-xs text-gray-400 dark:text-gray-500 mt-1 block">
            {prevPost.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
          </time>
        </a>
      ) : (
        <span class="text-xs text-gray-300 dark:text-gray-700 uppercase tracking-wide font-medium">
          ← Previous
        </span>
      )}
    </div>

    <!-- Context-aware center link -->
    <div class="bg-white dark:bg-gray-950 p-5 flex items-center justify-center">
      <a
        href={centerHref}
        class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      >
        {centerLabel}
      </a>
    </div>

    <!-- Next (newer) -->
    <div class="bg-white dark:bg-gray-950 p-5 md:text-right">
      {nextPost ? (
        <a href={`${postBasePath}/${nextPost.id}`} class="group block">
          <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide font-medium">
            Next →
          </span>
          <p class="mt-1 text-sm font-medium text-gray-900 dark:text-gray-100 group-hover:underline underline-offset-4 leading-snug">
            {nextPost.data.title}
          </p>
          <time class="text-xs text-gray-400 dark:text-gray-500 mt-1 block">
            {nextPost.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
          </time>
        </a>
      ) : (
        <span class="text-xs text-gray-300 dark:text-gray-700 uppercase tracking-wide font-medium">
          Next →
        </span>
      )}
    </div>

  </div>
</nav>
