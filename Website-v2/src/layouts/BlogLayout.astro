---
import BaseLayout from "./BaseLayout.astro";
import BlogSidebar from "../components/blog/BlogSidebar.astro";
import BlogPostNav from "../components/blog/BlogPostNav.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  date?: Date;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { title, description, image, date, prevPost = null, nextPost = null } = Astro.props;

// Derive current year/month from the URL so the sidebar can highlight the active entry.
// Matches /blog/YYYY/MM and /blog/YYYY/MM/slug — both have a 4-digit year at segment [1]
// and a 2-digit zero-padded month at segment [2].
const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const currentYear =
  pathParts[1] && /^\d{4}$/.test(pathParts[1]) ? Number(pathParts[1]) : null;
const currentMonth =
  pathParts[2] && /^\d{2}$/.test(pathParts[2]) ? Number(pathParts[2]) : null;

// Build archive for sidebar
const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

const allPosts = await getCollection("blog");

const yearMap = new Map<number, Map<number, number>>();
for (const post of allPosts) {
  const y = post.data.date.getFullYear();
  const m = post.data.date.getMonth();
  if (!yearMap.has(y)) yearMap.set(y, new Map());
  const mm = yearMap.get(y)!;
  mm.set(m, (mm.get(m) ?? 0) + 1);
}

const archive = [...yearMap.entries()]
  .sort((a, b) => b[0] - a[0])
  .map(([year, monthMap]) => ({
    year,
    months: [...monthMap.entries()]
      .sort((a, b) => b[0] - a[0])
      .map(([month, count]) => ({
        label: MONTHS[month],
        month: month + 1, // 1-indexed, matches URL segment
        count,
        href: `/blog/${year}/${String(month + 1).padStart(2, "0")}`,
      })),
  }));

const showPostNav = prevPost !== null || nextPost !== null;
---

<BaseLayout title={title} description={description} image={image}>

  <!-- Mobile archive toggle (hidden on desktop) -->
  <details class="blog-archive-toggle lg:hidden mb-6 rounded-md border border-gray-200 dark:border-gray-800">
    <summary
      class="flex cursor-pointer select-none items-center justify-between px-4 py-3 text-gray-600 dark:text-gray-400"
      aria-label="Toggle archive"
    >
      <!-- Hamburger icon: three horizontal lines -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="14"
        viewBox="0 0 18 14"
        fill="none"
        aria-hidden="true"
      >
        <path d="M0 1h18M0 7h18M0 13h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span aria-hidden="true" class="text-gray-400 dark:text-gray-600 text-xs">▾</span>
    </summary>
    <div class="px-4 pb-5 pt-3 border-t border-gray-200 dark:border-gray-800">
      <BlogSidebar archive={archive} currentYear={currentYear} currentMonth={currentMonth} />
    </div>
  </details>

  <!-- Two-column layout: sidebar (lg) + content -->
  <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-12 lg:items-start">

    <!-- Desktop sidebar (hidden on mobile) -->
    <aside class="hidden lg:block">
      <div class="sticky top-8">
        <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-4">
          Archive
        </p>
        <BlogSidebar archive={archive} currentYear={currentYear} currentMonth={currentMonth} />
      </div>
    </aside>

    <!-- Content column -->
    <div class="min-w-0">
      {title ? (
        <article class="prose prose-gray dark:prose-invert max-w-none">
          <header class="mb-8 not-prose">
            <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
            {date && (
              <time
                class="text-sm text-gray-500 dark:text-gray-400 mt-2 block"
                datetime={date.toISOString()}
              >
                {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
            )}
          </header>
          <slot />
        </article>
      ) : (
        <slot />
      )}

      {showPostNav && <BlogPostNav prevPost={prevPost} nextPost={nextPost} />}
    </div>

  </div>
</BaseLayout>
