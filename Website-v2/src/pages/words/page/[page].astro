---
import { getCollection, type CollectionEntry } from "astro:content";
import type { PaginateFunction } from "astro";
import WordsLayout from "../../../layouts/WordsLayout.astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allEntries = (await getCollection("words"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  // Pages 2+ only; page 1 is handled by words/index.astro
  return paginate(allEntries, { pageSize: 10 })
    .filter(({ params }) => Number(params.page) >= 2);
}

interface Props {
  page: {
    data: CollectionEntry<"words">[];
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
}

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/words" : (page.url.prev ?? "/words");
const nextUrl = page.url.next ?? null;

const wordsMetaEntries = await getCollection("wordsMeta");
const meta = wordsMetaEntries[0]?.data;
const sectionTitle = meta?.title ?? "";
const subtitle = meta?.subtitle ?? "";
const blurb = meta?.blurb ?? "";
---

<WordsLayout description="Poetry, prose, and essays by Greg Marine.">
  <section class="space-y-8">
    <div class="pb-6 border-b border-gray-100 dark:border-gray-800 space-y-1">
      {sectionTitle ? (
        <h1 class="text-3xl font-bold tracking-tight font-serif leading-snug">{sectionTitle}</h1>
      ) : (
        <h1 class="text-3xl font-bold tracking-tight">Words</h1>
      )}
      {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400">{subtitle}</p>}
      {blurb && <p class="text-sm italic text-gray-400 dark:text-gray-500">{blurb}</p>}
    </div>
    <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
      {page.data.map((entry) => (
        <li class="pt-6 first:pt-0 space-y-1.5">
          <a href={`/words/${entry.id}`} class="group block space-y-1">
            <h2 class="text-xl font-semibold group-hover:underline underline-offset-4">{entry.data.title}</h2>
            <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
              <time datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              {entry.data.form && <span>&middot; {entry.data.form}</span>}
            </div>
            {entry.data.description && (
              <p class="text-gray-600 dark:text-gray-400">{entry.data.description}</p>
            )}
          </a>
          {entry.data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-1.5">
              {entry.data.tags.map((tag: string) => (
                <li>
                  <a
                    href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                    class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
                  >
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <nav class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-800 text-sm">
      <div class="w-20">
        <a href={prevUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">← Newer</a>
      </div>
      <span class="text-xs text-gray-400 dark:text-gray-500">Page {page.currentPage} of {page.lastPage}</span>
      <div class="w-20 text-right">
        {nextUrl && (
          <a href={nextUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">Older →</a>
        )}
      </div>
    </nav>
  </section>
</WordsLayout>
