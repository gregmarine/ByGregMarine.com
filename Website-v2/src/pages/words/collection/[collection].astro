---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import WordsLayout from "../../../layouts/WordsLayout.astro";

export async function getStaticPaths() {
  const allEntries = await getCollection("words");

  const buckets = new Map<string, CollectionEntry<"words">[]>();
  for (const entry of allEntries) {
    if (!entry.data.collection) continue;
    const c = entry.data.collection;
    if (!buckets.has(c)) buckets.set(c, []);
    buckets.get(c)!.push(entry);
  }

  return [...buckets.entries()].map(([collection, entries]) => ({
    params: { collection },
    props: {
      collection,
      entries: entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

interface Props {
  collection: string;
  entries: CollectionEntry<"words">[];
}

const { collection, entries } = Astro.props;

const label = collection.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
---

<WordsLayout description={`Words in the ${label} collection.`}>
  <section class="space-y-8">
    <h1 class="text-3xl font-bold tracking-tight">{label}</h1>
    {entries.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">No entries in this collection yet.</p>
    ) : (
      <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
        {entries.map((entry) => (
          <li class="pt-6 first:pt-0">
            <a href={`/words/${entry.id}`} class="group block space-y-1">
              <h2 class="text-xl font-semibold group-hover:underline underline-offset-4">{entry.data.title}</h2>
              <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
                <time datetime={entry.data.date.toISOString()}>
                  {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                {entry.data.form && <span>&middot; {entry.data.form}</span>}
              </div>
              {entry.data.description && (
                <p class="text-gray-600 dark:text-gray-400">{entry.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</WordsLayout>
