---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import PhotosLayout from "../../layouts/PhotosLayout.astro";

export async function getStaticPaths() {
  const photos = await getCollection("photos");
  return photos.map((photo) => ({ params: { slug: photo.id }, props: { photo } }));
}

interface Props {
  photo: CollectionEntry<"photos">;
}

const { photo } = Astro.props;
const { Content } = await render(photo);

// Scope prev/next to the same collection group (named collection or uncollected "other")
const collectionKey = photo.data.collection ?? null;
const scopedPhotos = (await getCollection("photos"))
  .filter((p) => (p.data.collection ?? null) === collectionKey)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const index = scopedPhotos.findIndex((p) => p.id === photo.id);
const prevPost = scopedPhotos.length > 1 ? (scopedPhotos[index + 1] ?? null) : null; // older
const nextPost = scopedPhotos.length > 1 ? (scopedPhotos[index - 1] ?? null) : null; // newer
---

<PhotosLayout
  title={photo.data.title}
  description={photo.data.description}
  image={photo.data.images[0]?.src.src}
  date={photo.data.date}
  prevPost={prevPost}
  nextPost={nextPost}
  currentCollection={photo.data.collection ?? "other"}
  collection={photo.data.collection ?? null}
>
  <div class="not-prose space-y-6 mb-8">
    {photo.data.images.map((img) => (
      <figure>
        <Image src={img.src} alt={img.caption ?? photo.data.title} class="rounded-md w-full" />
        {img.caption && (
          <figcaption class="mt-2 text-sm text-gray-500 dark:text-gray-400">{img.caption}</figcaption>
        )}
      </figure>
    ))}
  </div>
  {photo.data.location && (
    <p class="not-prose text-sm text-gray-500 dark:text-gray-400 mb-6">{photo.data.location}</p>
  )}
  <Content />
  {photo.data.tags.length > 0 && (
    <div class="not-prose mt-8 pt-6 border-t border-gray-100 dark:border-gray-800">
      <ul class="flex flex-wrap gap-2">
        {photo.data.tags.map((tag: string) => (
          <li>
            <a
              href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
              class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
            >
              {tag}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</PhotosLayout>
