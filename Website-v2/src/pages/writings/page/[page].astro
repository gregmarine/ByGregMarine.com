---
import { getCollection } from "astro:content";
import type { PaginateFunction } from "astro";
import WritingsLayout from "../../../layouts/WritingsLayout.astro";
import { buildWritingsDisplayList, type WritingsDisplayItem } from "@/lib/writings";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allItems = buildWritingsDisplayList(await getCollection("writings"));
  // Pages 2+ only; page 1 is handled by writings/index.astro
  return paginate(allItems, { pageSize: 10 })
    .filter(({ params }) => Number(params.page) >= 2);
}

interface Props {
  page: {
    data: WritingsDisplayItem[];
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
}

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/writings" : (page.url.prev ?? "/writings");
const nextUrl = page.url.next ?? null;

const writingsMetaEntries = await getCollection("writingsMeta");
const meta = writingsMetaEntries[0]?.data;
const sectionTitle = meta?.title ?? "";
const subtitle = meta?.subtitle ?? "";
const tagline = meta?.tagline ?? "";
---

<WritingsLayout description="Poetry, prose, and essays by Greg Marine.">
  <section class="space-y-8">
    <div class="pb-6 border-b border-gray-100 dark:border-gray-800 space-y-1">
      {sectionTitle ? (
        <h1 class="text-3xl font-bold tracking-tight leading-snug">{sectionTitle}</h1>
      ) : (
        <h1 class="text-3xl font-bold tracking-tight">Writings</h1>
      )}
      {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400">{subtitle}</p>}
      {tagline && <p class="text-sm italic text-gray-400 dark:text-gray-500">{tagline}</p>}
    </div>
    <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
      {page.data.map((entry) => (
        <li class="pt-6 first:pt-0 space-y-1.5">
          <a href={entry.href} class="group block space-y-1">
            <h2 class="text-xl font-semibold group-hover:underline underline-offset-4">{entry.title}</h2>
            <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
              <time datetime={entry.date.toISOString()}>
                {entry.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              {entry.form && <span>&middot; {entry.form}</span>}
            </div>
            {entry.description && (
              <p class="text-gray-600 dark:text-gray-400">{entry.description}</p>
            )}
          </a>
          {entry.tags.length > 0 && (
            <ul class="flex flex-wrap gap-1.5">
              {entry.tags.map((tag: string) => (
                <li>
                  <a
                    href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                    class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
                  >
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <nav class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-800 text-sm">
      <div class="w-20">
        <a href={prevUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">← Newer</a>
      </div>
      <span class="text-xs text-gray-400 dark:text-gray-500">Page {page.currentPage} of {page.lastPage}</span>
      <div class="w-20 text-right">
        {nextUrl && (
          <a href={nextUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">Older →</a>
        )}
      </div>
    </nav>
  </section>
</WritingsLayout>
