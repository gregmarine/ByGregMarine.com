---
import { getCollection, type CollectionEntry } from "astro:content";
import type { PaginateFunction } from "astro";
import ArtLayout from "../../../layouts/ArtLayout.astro";
import { cloudinaryAuto } from "@/lib/cloudinary";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allPieces = (await getCollection("art"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  // Pages 2+ only; page 1 is handled by art/index.astro
  return paginate(allPieces, { pageSize: 10 })
    .filter(({ params }) => Number(params.page) >= 2);
}

interface Props {
  page: {
    data: CollectionEntry<"art">[];
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
}

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/art" : (page.url.prev ?? "/art");
const nextUrl = page.url.next ?? null;

const artMetaEntries = await getCollection("artMeta");
const meta = artMetaEntries[0]?.data;
const sectionTitle = meta?.title ?? "";
const subtitle = meta?.subtitle ?? "";
const tagline = meta?.tagline ?? "";
---

<ArtLayout description="Artwork by Greg Marine.">
  <section class="space-y-8">
    <div class="pb-6 border-b border-gray-100 dark:border-gray-800 space-y-1">
      {sectionTitle ? (
        <h1 class="text-3xl font-bold tracking-tight leading-snug">{sectionTitle}</h1>
      ) : (
        <h1 class="text-3xl font-bold tracking-tight">Art</h1>
      )}
      {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400">{subtitle}</p>}
      {tagline && <p class="text-sm italic text-gray-400 dark:text-gray-500">{tagline}</p>}
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {page.data.map((piece) => (
        <li>
          <a href={`/art/${piece.id}`} class="group block space-y-2">
            <div class="aspect-square overflow-hidden rounded-md bg-gray-100 dark:bg-gray-800">
              <img
                src={cloudinaryAuto(piece.data.images[0].src)}
                alt={piece.data.images[0].caption ?? piece.data.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </div>
            <h2 class="text-sm font-medium group-hover:underline underline-offset-4">{piece.data.title}</h2>
            {piece.data.medium && (
              <p class="text-xs text-gray-500 dark:text-gray-400">{piece.data.medium}</p>
            )}
          </a>
          {piece.data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-1.5 mt-1">
              {piece.data.tags.map((tag: string) => (
                <li>
                  <a
                    href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                    class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
                  >
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <nav class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-800 text-sm">
      <div class="w-20">
        <a href={prevUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">← Newer</a>
      </div>
      <span class="text-xs text-gray-400 dark:text-gray-500">Page {page.currentPage} of {page.lastPage}</span>
      <div class="w-20 text-right">
        {nextUrl && (
          <a href={nextUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">Older →</a>
        )}
      </div>
    </nav>
  </section>
</ArtLayout>
