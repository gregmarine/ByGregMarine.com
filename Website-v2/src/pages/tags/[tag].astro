---
import { getCollection } from "astro:content";
import TagLayout from "../../layouts/TagLayout.astro";

export async function getStaticPaths() {
  const [blogPosts, photos, artPieces, wordsEntries] = await Promise.all([
    getCollection("blog"),
    getCollection("photos"),
    getCollection("art"),
    getCollection("words"),
  ]);

  const tagSlugs = new Set<string>();
  for (const entry of [...blogPosts, ...photos, ...artPieces, ...wordsEntries]) {
    for (const tag of entry.data.tags) {
      tagSlugs.add(tag.toLowerCase().replace(/\s+/g, "-"));
    }
  }

  return [...tagSlugs].map((tag) => ({ params: { tag }, props: { tag } }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const displayTag = tag.replace(/-/g, " ");

function matchesTag(tags: string[], slug: string): boolean {
  return tags.some((t) => t.toLowerCase().replace(/\s+/g, "-") === slug);
}

const [blogPosts, photos, artPieces, wordsEntries] = await Promise.all([
  getCollection("blog"),
  getCollection("photos"),
  getCollection("art"),
  getCollection("words"),
]);

type TagEntry = {
  type: "blog" | "photo" | "art" | "word";
  title: string;
  href: string;
  date: Date;
  tags: string[];
};

const entries: TagEntry[] = [
  ...blogPosts
    .filter((p) => matchesTag(p.data.tags, tag))
    .map((p): TagEntry => ({ type: "blog", title: p.data.title, href: `/blog/${p.id}`, date: p.data.date, tags: p.data.tags })),
  ...photos
    .filter((p) => matchesTag(p.data.tags, tag))
    .map((p): TagEntry => ({ type: "photo", title: p.data.title, href: `/photos/${p.id}`, date: p.data.date, tags: p.data.tags })),
  ...artPieces
    .filter((p) => matchesTag(p.data.tags, tag))
    .map((p): TagEntry => ({ type: "art", title: p.data.title, href: `/art/${p.id}`, date: p.data.date, tags: p.data.tags })),
  ...wordsEntries
    .filter((p) => matchesTag(p.data.tags, tag))
    .map((p): TagEntry => ({ type: "word", title: p.data.title, href: `/words/${p.id}`, date: p.data.date, tags: p.data.tags })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<TagLayout title={`Tagged: ${displayTag}`} description={`All entries tagged "${displayTag}".`}>
  <section class="space-y-8">
    <h1 class="text-3xl font-bold tracking-tight">Tagged: {displayTag}</h1>
    {entries.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">No entries with this tag yet.</p>
    ) : (
      <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
        {entries.map((entry) => (
          <li class="pt-6 first:pt-0 space-y-2">
            <div class="flex items-start gap-3">
              <span class="mt-0.5 shrink-0 text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded">
                {entry.type}
              </span>
              <div class="min-w-0 flex-1 space-y-1">
                <a
                  href={entry.href}
                  class="block text-lg font-semibold hover:underline underline-offset-4 leading-snug"
                >
                  {entry.title}
                </a>
                <time
                  class="block text-sm text-gray-500 dark:text-gray-400"
                  datetime={entry.date.toISOString()}
                >
                  {entry.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
              </div>
            </div>
            {entry.tags.length > 0 && (
              <ul class="flex flex-wrap gap-1.5 pl-0">
                {entry.tags.map((t) => {
                  const tSlug = t.toLowerCase().replace(/\s+/g, "-");
                  return (
                    <li>
                      <a
                        href={`/tags/${tSlug}`}
                        aria-current={tSlug === tag ? "page" : undefined}
                        class:list={[
                          "text-xs px-2 py-0.5 rounded transition-colors",
                          tSlug === tag
                            ? "text-gray-900 dark:text-gray-100 bg-gray-200 dark:bg-gray-700 font-medium"
                            : "text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700",
                        ]}
                      >
                        {t}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </li>
        ))}
      </ul>
    )}
  </section>
</TagLayout>
