---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

const PAGE_SIZE = 10;
const allPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const posts = allPosts.slice(0, PAGE_SIZE);
const nextUrl = totalPages > 1 ? "/blog/page/2" : null;

const blogMetaEntries = await getCollection("blogMeta");
const meta = blogMetaEntries[0]?.data;
const sectionTitle = meta?.title ?? "";
const subtitle = meta?.subtitle ?? "";
const blurb = meta?.blurb ?? "";
---

<BlogLayout description="Writing and thoughts by Greg Marine.">
  <section class="space-y-8">
    <div class="pb-6 border-b border-gray-100 dark:border-gray-800 space-y-1">
      {sectionTitle ? (
        <h1 class="text-3xl font-bold tracking-tight font-serif leading-snug">{sectionTitle}</h1>
      ) : (
        <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
      )}
      {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400">{subtitle}</p>}
      {blurb && <p class="text-sm italic text-gray-400 dark:text-gray-500">{blurb}</p>}
    </div>
    {posts.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">No posts yet. Check back soon.</p>
    ) : (
      <>
        <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
          {posts.map((post) => (
            <li class="pt-6 first:pt-0 space-y-1.5">
              <a href={`/blog/${post.id}`} class="group block space-y-1">
                <h2 class="text-xl font-semibold group-hover:underline underline-offset-4">{post.data.title}</h2>
                <time class="text-sm text-gray-500 dark:text-gray-400" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                {post.data.description && (
                  <p class="text-gray-600 dark:text-gray-400">{post.data.description}</p>
                )}
              </a>
              {post.data.tags.length > 0 && (
                <ul class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <li>
                      <a
                        href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                        class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
                      >
                        {tag}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
        <nav class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-800 text-sm">
          <div class="w-20">
            {/* page 1 — no previous */}
          </div>
          <span class="text-xs text-gray-400 dark:text-gray-500">Page 1 of {totalPages}</span>
          <div class="w-20 text-right">
            {nextUrl && (
              <a href={nextUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">Older →</a>
            )}
          </div>
        </nav>
      </>
    )}
  </section>
</BlogLayout>
