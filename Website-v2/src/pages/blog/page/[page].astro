---
import { getCollection, type CollectionEntry } from "astro:content";
import type { PaginateFunction } from "astro";
import BlogLayout from "../../../layouts/BlogLayout.astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allPosts = (await getCollection("blog"))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  // Pages 2+ only; page 1 is handled by blog/index.astro
  return paginate(allPosts, { pageSize: 10 })
    .filter(({ params }) => Number(params.page) >= 2);
}

interface Props {
  page: {
    data: CollectionEntry<"blog">[];
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string };
  };
}

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/blog" : (page.url.prev ?? "/blog");
const nextUrl = page.url.next ?? null;

const blogMetaEntries = await getCollection("blogMeta");
const blurb = blogMetaEntries[0]?.data?.blurb ?? "";
---

<BlogLayout description="Writing and thoughts by Greg Marine.">
  <section class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
      {blurb && <p class="mt-2 text-base italic text-gray-500 dark:text-gray-400">{blurb}</p>}
    </div>
    <ul class="space-y-6 divide-y divide-gray-100 dark:divide-gray-800">
      {page.data.map((post) => (
        <li class="pt-6 first:pt-0 space-y-1.5">
          <a href={`/blog/${post.id}`} class="group block space-y-1">
            <h2 class="text-xl font-semibold group-hover:underline underline-offset-4">{post.data.title}</h2>
            <time class="text-sm text-gray-500 dark:text-gray-400" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </time>
            {post.data.description && (
              <p class="text-gray-600 dark:text-gray-400">{post.data.description}</p>
            )}
          </a>
          {post.data.tags.length > 0 && (
            <ul class="flex flex-wrap gap-1.5">
              {post.data.tags.map((tag: string) => (
                <li>
                  <a
                    href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                    class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-2 py-0.5 rounded transition-colors"
                  >
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <nav class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-800 text-sm">
      <div class="w-20">
        <a href={prevUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">← Newer</a>
      </div>
      <span class="text-xs text-gray-400 dark:text-gray-500">Page {page.currentPage} of {page.lastPage}</span>
      <div class="w-20 text-right">
        {nextUrl && (
          <a href={nextUrl} class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">Older →</a>
        )}
      </div>
    </nav>
  </section>
</BlogLayout>
